# ── API Keys ────────────────────────────────────────────────────────────────
# ENTSO-E Transparency Platform — register at https://transparency.entsoe.eu
#   My Account Settings → Web API Security Token
ENTSOE_API_KEY=your_entsoe_key_here

# Elexon BMRS API — open, no key required
# ELEXON_API_KEY=

# NESO CKAN API — open, no key required
# NESO_API_KEY=

# ── Date Range ───────────────────────────────────────────────────────────────
START_DATE=2018-01-01
END_DATE=2019-01-01

# ── Data Sources ─────────────────────────────────────────────────────────────
# Switch any source to "CSV" to load from a local file instead of the API.
DEFAULT_DEMAND_FORECAST_SOURCE=NESO_API   # NESO_API | ENTSOE | CSV
# Note: ENTSOE demand forecast (A65) uses a single daily snapshot stamped at D-1 10:30
# Europe/London — only the fc_da_d1_1030 static feature is meaningful with this source.
DEFAULT_WIND_FORECAST_SOURCE=ELEXON       # ELEXON | CSV
DEFAULT_GENERATION_ACTUAL_SOURCE=ELEXON   # ELEXON | CSV
DEFAULT_DAY_AHEAD_PRICE_SOURCE=ENTSOE     # ENTSOE | CSV
DEFAULT_MARKET_INDEX_SOURCE=ELEXON        # ELEXON | CSV
DEFAULT_DEMAND_ACTUAL_SOURCE=ELEXON       # ELEXON | CSV
DEFAULT_IMBALANCE_PRICE_SOURCE=ELEXON     # ELEXON | CSV
