{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Static Analysis",
      "configurations": ["mypy: type check", "flake8: lint"]
    }
  ],
  "configurations": [
    {
      "name": "mypy: type check",
      "type": "debugpy",
      "request": "launch",
      "module": "mypy",
      "args": ["src/", "--config-file", "pyproject.toml"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "presentation": { "hidden": true }
    },
    {
      "name": "flake8: lint",
      "type": "debugpy",
      "request": "launch",
      "module": "flake8",
      "args": ["src/", "tests/"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "presentation": { "hidden": true }
    },
    {
      "name": "Run All Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests", "-v"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${command:python.interpreterPath}",
      "justMyCode": false
    },
    {
      "name": "Run Full Pipeline",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${command:python.interpreterPath}",
      "justMyCode": false,
      "stopOnEntry": false
    },
    {
      "name": "Run Features Mode",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--mode", "features"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${command:python.interpreterPath}",
      "justMyCode": false,
      "stopOnEntry": false
    },
    {
      "name": "Run Model Mode",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--mode", "model"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${command:python.interpreterPath}",
      "justMyCode": false,
      "stopOnEntry": false
    },
    {
      "name": "Debug Pipeline",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${command:python.interpreterPath}",
      "justMyCode": false,
      "stopOnEntry": false
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${command:python.interpreterPath}"
    }
  ]
}