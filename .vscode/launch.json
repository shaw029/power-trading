{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Static Analysis",
      "configurations": ["mypy: type check", "flake8: lint"]
    }
  ],
  "configurations": [
    {
      "name": "mypy: type check",
      "type": "debugpy",
      "request": "launch",
      "module": "mypy",
      "args": ["src/", "--config-file", "pyproject.toml"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "presentation": { "hidden": true }
    },
    {
      "name": "flake8: lint",
      "type": "debugpy",
      "request": "launch",
      "module": "flake8",
      "args": ["src/", "tests/"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "presentation": { "hidden": true }
    },
    {
      "name": "Download Only",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--mode", "download", "--config", "configs/config.yaml"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": { "PYTHONPATH": "${workspaceFolder}" },
      "python": "${command:python.interpreterPath}",
      "justMyCode": false,
      "stopOnEntry": false
    },
    {
      "name": "Features Only",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--mode", "features", "--config", "configs/config.yaml"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": { "PYTHONPATH": "${workspaceFolder}" },
      "python": "${command:python.interpreterPath}",
      "justMyCode": false,
      "stopOnEntry": false
    },
    {
      "name": "Virtual: Train & Backtest",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--mode", "model", "--config", "configs/config.yaml"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": { "PYTHONPATH": "${workspaceFolder}" },
      "python": "${command:python.interpreterPath}",
      "justMyCode": false,
      "stopOnEntry": false
    },
    {
      "name": "Full Pipeline",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--config", "configs/config.yaml"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": { "PYTHONPATH": "${workspaceFolder}" },
      "python": "${command:python.interpreterPath}",
      "justMyCode": false,
      "stopOnEntry": false
    },
    {
      "name": "Run All Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests", "-v"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": { "PYTHONPATH": "${workspaceFolder}" },
      "python": "${command:python.interpreterPath}",
      "justMyCode": false
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": { "PYTHONPATH": "${workspaceFolder}" },
      "python": "${command:python.interpreterPath}"
    }
  ]
}
